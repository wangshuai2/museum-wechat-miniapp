/* pages/login/login.wxss */

.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.form-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 48rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 96rpx;
}

.input-icon {
  margin-right: 16rpx;
}

.form-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
}

.toggle-icon {
  padding: 16rpx;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  border: none;
}

.submit-btn.disabled {
  opacity: 0.6;
}

.submit-btn::after {
  border: none;
}

/* 切换模式 */
.switch-mode {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #999;
}

.switch-btn {
  color: #1890ff;
  margin-left: 8rpx;
}

/* 其他登录方式 */
.other-login {
  width: 100%;
  margin-top: 60rpx;
}

.divider-line {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.divider-line::before,
.divider-line::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.divider-line text {
  padding: 0 24rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.other-login-btns {
  display: flex;
  justify-content: center;
}

.login-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 48rpx;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
}

.login-btn text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #fff;
}

/* 用户协议 */
.agreement {
  margin-top: 60rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
}

.agreement .link {
  color: #fff;
}