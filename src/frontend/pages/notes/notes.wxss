/* pages/notes/notes.wxss */

.notes-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 头部统计 */
.stats-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 30rpx;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-item .arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #999;
}

/* 笔记列表 */
.notes-list {
  padding: 20rpx;
}

.note-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 封面图 */
.note-cover {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.image-count {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  padding: 4rpx 12rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #fff;
}

/* 笔记内容 */
.note-content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.note-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}

/* 标签 */
.note-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 4rpx 16rpx;
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890ff;
  font-size: 22rpx;
  border-radius: 20rpx;
}

/* 底部信息 */
.note-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.note-location {
  display: flex;
  align-items: center;
  overflow: hidden;
  flex: 1;
  margin-right: 20rpx;
}

.museum-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200rpx;
}

.divider {
  margin: 0 8rpx;
}

.exhibit-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.note-meta {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
  color: #999;
}

.meta-item text:first-child {
  margin-right: 4rpx;
}

.note-date {
  flex-shrink: 0;
}

/* 加载状态 */
.loading-status {
  padding: 40rpx 0;
  text-align: center;
}

.loading-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 26rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-tip text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.create-btn {
  padding: 16rpx 48rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.create-btn::after {
  border: none;
}

.no-more {
  font-size: 24rpx;
  color: #ccc;
}

.loading-more {
  font-size: 24rpx;
  color: #999;
}

/* 创建按钮 */
.create-fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}

/* 筛选弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.filter-modal {
  width: 100%;
  max-height: 70vh;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.museum-list {
  max-height: 60vh;
  padding: 20rpx 0;
}

.museum-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  font-size: 28rpx;
  color: #333;
}

.museum-item.active {
  color: #1890ff;
  background-color: rgba(24, 144, 255, 0.05);
}

.check-icon {
  color: #1890ff;
  font-size: 28rpx;
}