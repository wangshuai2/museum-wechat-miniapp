<!--pages/notes/notes.wxml-->
<view class="notes-container">
  <!-- 头部统计 -->
  <view class="stats-header">
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-value">{{statistics.totalNotes || 0}}</text>
        <text class="stat-label">篇笔记</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{statistics.totalWords || 0}}</text>
        <text class="stat-label">字</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{statistics.museumCount || 0}}</text>
        <text class="stat-label">座博物馆</text>
      </view>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item" bindtap="showFilterModal">
      <text>{{selectedMuseumName}}</text>
      <text class="arrow">▼</text>
    </view>
  </view>

  <!-- 笔记列表 -->
  <view class="notes-list">
    <block wx:for="{{notes}}" wx:key="_id">
      <view class="note-card" data-id="{{item._id}}" bindtap="goToNoteDetail">
        <!-- 封面图 -->
        <view class="note-cover" wx:if="{{item.images.length > 0}}">
          <image 
            class="cover-image" 
            src="{{item.images[0]}}" 
            mode="aspectFill"
            data-url="{{item.images[0]}}"
            data-urls="{{item.images}}"
            catchtap="previewImage"
          />
          <view class="image-count" wx:if="{{item.images.length > 1}}">
            <text>{{item.images.length}}图</text>
          </view>
        </view>

        <!-- 笔记内容 -->
        <view class="note-content">
          <!-- 标题 -->
          <view class="note-title" wx:if="{{item.title}}">
            <text>{{item.title}}</text>
          </view>
          
          <!-- 摘要 -->
          <view class="note-summary">
            <text>{{item.content}}</text>
          </view>

          <!-- 标签 -->
          <view class="note-tags" wx:if="{{item.tags.length > 0}}">
            <text 
              wx:for="{{item.tags}}" 
              wx:for-item="tag"
              wx:key="*this" 
              class="tag"
            >{{tag}}</text>
          </view>

          <!-- 底部信息 -->
          <view class="note-footer">
            <view class="note-location">
              <text class="museum-name">{{item.museumName}}</text>
              <text class="divider" wx:if="{{item.exhibitName}}">·</text>
              <text class="exhibit-name" wx:if="{{item.exhibitName}}">{{item.exhibitName}}</text>
            </view>
            <view class="note-meta">
              <view class="meta-item" wx:if="{{item.visibility === 'public'}}">
                <text class="iconfont">👁</text>
                <text>{{item.likeCount}}</text>
              </view>
              <text class="note-date">{{item.createdAt}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 加载状态 -->
    <view class="loading-status">
      <view wx:if="{{loading}}" class="loading-tip">
        <view class="loading-spinner"></view>
        <text>加载中...</text>
      </view>
      <view wx:if="{{!loading && notes.length === 0}}" class="empty-tip">
        <image class="empty-icon" src="/assets/images/empty.png" mode="aspectFit" />
        <text>暂无笔记</text>
        <button class="create-btn" bindtap="goToCreateNote">写一篇</button>
      </view>
      <view wx:if="{{!loading && !hasMore && notes.length > 0}}" class="no-more">
        <text>— 没有更多了 —</text>
      </view>
      <view wx:if="{{loadingMore}}" class="loading-more">
        <text>加载更多...</text>
      </view>
    </view>
  </view>

  <!-- 创建按钮 -->
  <view class="create-fab" bindtap="goToCreateNote">
    <text class="fab-icon">+</text>
  </view>
</view>

<!-- 筛选弹窗 -->
<view wx:if="{{showFilter}}" class="modal-mask" bindtap="hideFilterModal">
  <view class="filter-modal" catchtap="">
    <view class="modal-header">
      <text class="modal-title">选择博物馆</text>
      <text class="modal-close" bindtap="hideFilterModal">×</text>
    </view>
    
    <scroll-view class="museum-list" scroll-y>
      <view 
        class="museum-item {{!selectedMuseumId ? 'active' : ''}}"
        data-id=""
        data-name="全部博物馆"
        bindtap="selectMuseum"
      >
        <text>全部博物馆</text>
        <text class="check-icon" wx:if="{{!selectedMuseumId}}">✓</text>
      </view>
      <view 
        wx:for="{{museums}}" 
        wx:key="_id"
        class="museum-item {{selectedMuseumId === item._id ? 'active' : ''}}"
        data-id="{{item._id}}"
        data-name="{{item.name}}"
        bindtap="selectMuseum"
      >
        <text>{{item.name}}</text>
        <text class="check-icon" wx:if="{{selectedMuseumId === item._id}}">✓</text>
      </view>
    </scroll-view>
  </view>
</view>