/* pages/favorites/favorites.wxss */

.favorites-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* Tab 切换 */
.tabs-header {
  display: flex;
  background-color: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  position: relative;
}

.tab-name {
  font-size: 30rpx;
  color: #666;
  margin-right: 8rpx;
}

.tab-count {
  font-size: 22rpx;
  color: #999;
  background-color: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.tab-item.active .tab-name {
  color: #1890ff;
  font-weight: 600;
}

.tab-item.active .tab-count {
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890ff;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #1890ff;
  border-radius: 3rpx;
}

/* 收藏列表 */
.favorites-list {
  padding: 20rpx;
}

/* 收藏卡片 */
.favorite-card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 封面图 */
.card-image-wrapper {
  position: relative;
  width: 100%;
  height: 300rpx;
}

.card-image {
  width: 100%;
  height: 100%;
}

/* 状态标签 */
.status-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
}

.status-badge.want {
  background-color: #faad14;
}

.status-badge.visited {
  background-color: #52c41a;
}

/* 参观次数 */
.visit-count {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
}

/* 卡片内容 */
.card-content {
  padding: 24rpx;
}

.card-header {
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 信息区域 */
.card-info {
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-item .iconfont {
  margin-right: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.location-info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.location-info .iconfont {
  margin-right: 8rpx;
}

.museum-name {
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.collect-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.status-btn {
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890ff;
}

.status-btn.want {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.status-btn.visited {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.remove-btn {
  background-color: #f5f5f5;
  color: #999;
}

/* 加载状态 */
.loading-status {
  padding: 40rpx 0;
  text-align: center;
}

.loading-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 26rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-tip text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx !important;
  color: #bbb !important;
}

.no-more {
  font-size: 24rpx;
  color: #ccc;
}

.loading-more {
  font-size: 24rpx;
  color: #999;
}