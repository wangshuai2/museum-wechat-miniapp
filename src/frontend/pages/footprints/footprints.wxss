/* pages/footprints/footprints.wxss */

.footprints-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 未登录状态 */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  min-height: 60vh;
}

.not-logged-in .empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.not-logged-in .login-tip {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 32rpx;
}

.not-logged-in .login-btn {
  padding: 20rpx 60rpx;
  background-color: #fff;
  color: #1890ff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
}

.not-logged-in .login-btn::after {
  border: none;
}

/* 统计区域 */
.stats-section {
  padding: 20rpx;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 40rpx 20rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* 足迹区域 */
.footprints-section {
  padding: 0 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

/* 足迹卡片列表 */
.footprints-list {
  /* 列表容器 */
}

.footprint-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.museum-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #f0f0f0;
}

.museum-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.museum-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.visit-time {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.visit-time icon {
  margin-right: 8rpx;
}

/* 卡片内容 */
.card-content {
  padding: 20rpx 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

/* 评分星星 */
.rating-stars {
  display: flex;
}

.star {
  font-size: 28rpx;
  color: #ddd;
  margin-left: 4rpx;
}

.star.active {
  color: #faad14;
}

/* 卡片底部 */
.card-footer {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: flex-end;
}

.view-detail {
  font-size: 26rpx;
  color: #1890ff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.explore-btn {
  padding: 20rpx 60rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.explore-btn::after {
  border: none;
}

/* 加载更多 */
.load-more {
  padding: 30rpx 0;
  display: flex;
  justify-content: center;
}

.loading {
  font-size: 26rpx;
  color: #999;
}

.load-more-btn {
  padding: 16rpx 40rpx;
  background-color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #1890ff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 没有更多 */
.no-more {
  padding: 30rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
}