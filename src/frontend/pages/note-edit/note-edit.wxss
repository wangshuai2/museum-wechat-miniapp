/* pages/note-edit/note-edit.wxss */

.edit-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 关联信息卡片 */
.info-card {
  margin: 20rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  border-left: 6rpx solid #1890ff;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.info-row:not(:last-child) {
  margin-bottom: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 表单区块 */
.form-section {
  margin: 20rpx;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.section-tip {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.char-count {
  margin-left: auto;
  font-size: 24rpx;
  color: #999;
}

/* 标题输入 */
.title-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  font-size: 30rpx;
}

/* 内容输入 */
.content-input {
  width: 100%;
  min-height: 300rpx;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.8;
}

/* 图片上传 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn text {
  color: #fff;
  font-size: 32rpx;
  line-height: 1;
}

.add-btn {
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: rgba(24, 144, 255, 0.1);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #1890ff;
}

.tag-delete {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #1890ff;
}

.suggested-tags {
  margin-bottom: 20rpx;
}

.suggest-title {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.suggest-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.suggest-tag {
  padding: 8rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.suggest-tag.disabled {
  opacity: 0.4;
}

.add-tag-btn {
  width: 100%;
  height: 80rpx;
  background-color: #f8f8f8;
  color: #666;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-tag-btn::after {
  border: none;
}

/* 可见性 */
.visibility-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.visibility-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.visibility-item.active {
  background-color: rgba(24, 144, 255, 0.05);
  border-color: #1890ff;
}

.radio-circle {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.visibility-item.active .radio-circle {
  border-color: #1890ff;
}

.radio-dot {
  width: 24rpx;
  height: 24rpx;
  background-color: #1890ff;
  border-radius: 50%;
}

.option-content {
  flex: 1;
}

.option-title {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #999;
}

/* 保存按钮 */
.save-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn::after {
  border: none;
}

.save-btn.disabled {
  opacity: 0.6;
}

/* 标签输入弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-modal {
  width: 80%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.tag-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  font-size: 30rpx;
  border-radius: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background-color: #fff;
  color: #666;
}

.modal-btn.confirm {
  background-color: #1890ff;
  color: #fff;
}