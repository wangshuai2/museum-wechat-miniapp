<!--pages/index/index.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <icon type="search" size="16" color="#999" class="search-icon" />
      <input 
        class="search-input"
        type="text"
        placeholder="搜索展品名称、标签..."
        value="{{searchValue}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
      <icon 
        wx:if="{{searchValue}}"
        type="clear" 
        size="16" 
        color="#999" 
        class="clear-icon"
        bindtap="onClearSearch"
      />
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view class="category-list">
      <view 
        wx:for="{{categories}}" 
        wx:key="*this"
        class="category-item {{currentCategory === item ? 'active' : ''}}"
        data-category="{{item}}"
        bindtap="onCategoryChange"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <!-- 展品列表 -->
  <view class="museum-list">
    <block wx:for="{{filteredList}}" wx:key="_id">
      <view 
        class="museum-card" 
        data-id="{{item._id}}"
        bindtap="goToDetail"
      >
        <image 
          class="museum-image" 
          src="{{item.imageUrl || '/assets/images/default-cover.jpg'}}" 
          mode="aspectFill"
        />
        <view class="museum-info">
          <view class="museum-header">
            <text class="museum-name">{{item.name}}</text>
            <text class="museum-category">{{item.category}}</text>
          </view>
          <text class="museum-desc">{{item.description}}</text>
          <view class="museum-footer">
            <view class="museum-location">
              <icon type="waiting" size="14" color="#1890ff" />
              <text>{{item.location}}</text>
            </view>
            <view class="museum-tags">
              <text 
                wx:for="{{item.tags}}" 
                wx:for-item="tag"
                wx:key="*this"
                class="tag"
              >{{tag}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <!-- 无更多数据 -->
    <view wx:if="{{!hasMore && filteredList.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && filteredList.length === 0}}" class="empty">
      <image class="empty-icon" src="/assets/images/empty.png" mode="aspectFit" />
      <text class="empty-text">暂无展品数据</text>
    </view>
  </view>
</view>