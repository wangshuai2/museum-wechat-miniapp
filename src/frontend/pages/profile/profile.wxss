/* pages/profile/profile.wxss */

.profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 未登录状态 */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
}

.login-tip {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 32rpx;
}

.login-btn {
  padding: 20rpx 60rpx;
  background-color: #fff;
  color: #1890ff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 24rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.user-actions {
  display: flex;
}

.user-actions .action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 32rpx;
  color: #fff;
  font-size: 24rpx;
}

.user-actions .action-btn text {
  margin-top: 8rpx;
}

/* 统计数据 */
.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx;
  margin: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-top: -40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #1890ff;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #eee;
}

/* 标签页 */
.tabs {
  display: flex;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #1890ff;
  border-radius: 2rpx;
}

/* 内容区域 */
.content-section {
  margin: 0 20rpx;
}

/* 参观足迹 */
.history-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-info {
  display: flex;
  flex-direction: column;
}

.history-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

.history-duration {
  font-size: 24rpx;
  color: #1890ff;
}

/* 预约列表 */
.reservation-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.reservation-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.reservation-item:last-child {
  border-bottom: none;
}

.reservation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.reservation-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.reservation-status {
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.status-pending {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.status-confirmed {
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890ff;
}

.status-completed {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.status-cancelled {
  background-color: rgba(153, 153, 153, 0.1);
  color: #999;
}

.reservation-detail {
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.detail-row icon {
  margin-right: 8rpx;
}

.reservation-actions {
  display: flex;
  justify-content: flex-end;
}

.reservation-actions .action-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  background-color: #f5f5f5;
  color: #666;
}

.reservation-actions .action-btn.primary {
  background-color: #1890ff;
  color: #fff;
}

.reservation-actions .action-btn.danger {
  background-color: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.empty-btn::after {
  border: none;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 20rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  color: #ff4d4f;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: 1rpx solid #ff4d4f;
}

.logout-btn::after {
  border: none;
}